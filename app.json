{
  "expo": {
    "name": "Equaly",
    "slug": "equaly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/equaly-logo-light.png",
    "scheme": "equaly",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.equaly.dev",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.equaly.dev",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/equaly-logo-light.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "Equaly",
      "shortName": "Equaly",
      "description": "Equaly — simple, fair, and fast."
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/equaly-logo-light.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/images/equaly-logo-dark.png",
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Equaly to access your photos to attach receipts.",
          "cameraPermission": "Allow Equaly to use the camera to capture receipts."
        }
      ],
      "expo-secure-store",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.843304455080-m1menm8cov2qrg1dln5n726k45osl0tj"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0c0b3a9c-c19c-4d4b-9b15-2ed51a8cbac7"
      }
    },
    "owner": "bewithsnehasish"
  }
}
